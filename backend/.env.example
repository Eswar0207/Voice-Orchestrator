# --- Database -----------------------------------------------------------
# Local: matches docker-compose.yml's postgres service.
# Production: GCP Cloud SQL (PostgreSQL) connection string.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/voice_orchestrator

# --- Vapi.ai --------------------------------------------------------------
VAPI_PRIVATE_KEY=your_vapi_private_key_here
VAPI_ASSISTANT_ID=your_vapi_assistant_id_here
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here
# Shared secret configured in the Vapi dashboard for webhook signing
VAPI_WEBHOOK_SECRET=your_vapi_webhook_shared_secret_here
VAPI_API_BASE=https://api.vapi.ai

# --- LLM (set at least one; OpenAI takes priority if both are set) --------
OPENAI_API_KEY=
GEMINI_API_KEY=
# Reserved for future use via the same provider-agnostic interface
ANTHROPIC_API_KEY=

# --- App --------------------------------------------------------------
ENVIRONMENT=local
CORS_ORIGINS=*
PORT=8000
